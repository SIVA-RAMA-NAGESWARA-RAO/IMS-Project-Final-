# ════════════════════════════════════════════════════════════════════════════
#  IMS Backend — Environment Variables (.env.example)
#  Copy to .env and fill in your values before running.
# ════════════════════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/ims
# Atlas example:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ims?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_to_a_different_long_random_secret_min_64_chars
REFRESH_TOKEN_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=ims_refresh

# ── CORS / Cookies ───────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173
COOKIE_SECURE=false
# Production: COOKIE_SECURE=true (requires HTTPS)

# ── Email (OTP + notifications) ───────────────────────────────────────────────
# Option A: Gmail SMTP (use an App Password, not your real password)
# Get an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="IMS Recruitment <no-reply@ims.example.com>"

# Option B: Resend (recommended for production) — swap all SMTP_* above with:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OTP Settings ─────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=10
GLOBAL_RATE_LIMIT_WINDOW_MINUTES=15
GLOBAL_RATE_LIMIT_MAX=300

# ── Cloudinary (resume/document uploads) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MAX_UPLOAD_SIZE_MB=5

# ── Video Meetings ────────────────────────────────────────────────────────────
#
# Option A: Jitsi Meet (DEFAULT — zero config, works out of the box!)
# Leave the variables below empty to use the free public Jitsi server.
# For self-hosted Jitsi: set JITSI_BASE_URL=https://your-jitsi-server.com
JITSI_BASE_URL=https://meet.jit.si
#
# Option B: Zoom Server-to-Server OAuth (replaces deprecated JWT app)
# Steps: Zoom Marketplace → Create App → "Server-to-Server OAuth" → Activate
# Scopes needed: meeting:write:meeting:admin, meeting:write:meeting
# ZOOM_ACCOUNT_ID=your_account_id
# ZOOM_CLIENT_ID=your_client_id
# ZOOM_CLIENT_SECRET=your_client_secret
#
# Option C: Google Meet placeholder (manual link generation)
# GOOGLE_MEET_BASE_URL=https://meet.google.com

# ── Analytics Service (Python/SQL — optional legacy) ──────────────────────────
ANALYTICS_SERVICE_URL=http://localhost:6000

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# The system auto-detects: Gemini preferred, falls back to Groq.
# Google Gemini 1.5 Flash (free tier — https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
# Groq Llama-3 (free tier — https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# ── Admin Bootstrap ────────────────────────────────────────────────────────────
# Used by: npm run seed:admin
ADMIN_EMAIL=admin@ims.example.com
ADMIN_PASSWORD=ChangeThisImmediately123!
ADMIN_NAME=System Admin
